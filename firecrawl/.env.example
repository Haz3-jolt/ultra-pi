# Copy to firecrawl/.env before running `docker compose up`.
PORT=3002
INTERNAL_PORT=3002
HOST=0.0.0.0
USE_DB_AUTHENTICATION=false

# Workers / concurrency — tune down for laptops
NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5

# Postgres (internal)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=nuq-postgres
POSTGRES_PORT=5432

# SearXNG metasearch — used by /search API
SEARXNG_ENDPOINT=http://searxng:8080
SEARXNG_EXTERNAL_PORT=8080

# Bull queue admin UI password (visit /admin/<KEY>/queues)
BULL_AUTH_KEY=changeme

# Optional AI features — leave blank unless you need /extract
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=
MODEL_EMBEDDING_NAME=
OLLAMA_BASE_URL=

# Logging
LOGGING_LEVEL=info
