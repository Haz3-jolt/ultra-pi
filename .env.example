# Copy to .env and fill in values you need.
# .env is gitignored.

# ── LLM provider keys ──
ANTHROPIC_API_KEY=

# ── Jina Reader / Search ──
# Cloud API for web scraping and search. Get a key at https://jina.ai
JINA_API_KEY=

